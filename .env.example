# ---------------------------------------------------------------------------
# Aman Conseil — environment variables
# Copy to .env.local for development. Set the same vars in Vercel for prod.
# NEVER commit a filled-in .env file. Secrets live only in Vercel env vars.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.amanconseil.ma

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # only if a client read is needed (none public in v1)
SUPABASE_SERVICE_ROLE_KEY=              # SERVER ONLY — never expose to the client

# Email notifications (Resend)
RESEND_API_KEY=
NOTIFY_EMAIL=contact@amanconseil.ma
RESEND_FROM_EMAIL=Aman Conseil <noreply@amanconseil.ma>

# Anti-spam (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# WhatsApp click-to-chat (international format, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=2126XXXXXXXX

# Analytics (optional, loaded behind consent)
NEXT_PUBLIC_GA_ID=

# Admin back-office (comma-separated allow-list of admin emails)
ADMIN_ALLOWED_EMAILS=you@example.com
